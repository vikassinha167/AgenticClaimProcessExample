# Azure AI services endpoint
AZURE_AI_SERVICES_ENDPOINT=https://tpe-ai-foundry.cognitiveservices.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://tpe-search-index.search.windows.net
AZURE_SEARCH_INDEX=healthcare-fraud-index

# Azure AI Foundry
AZURE_FOUNDRY_ENDPOINT=https://tpe-ai-foundry.services.ai.azure.com/api/projects/TPE-Project
AZURE_FOUNDRY_PROJECT_ID=TPE-Project
AZURE_FOUNDRY_SCOPE=https://cognitiveservices.azure.com/.default
AZURE_FOUNDRY_AGENT_VERSION=1

# Azure Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://tpe-docintel.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY_SECRET_NAME=AzureFormRecognizerKey

# Azure Key Vault access
AZURE_KEY_VAULT_URL=https://tpe-key-vault-tpe.vault.azure.net/
AZURE_KEY_VAULT_CLIENT_ID=

# Azure Key Vault secret names for service credentials
AZURE_OPENAI_KEY_SECRET_NAME=AzureOpenAIKey
AZURE_FORM_RECOGNIZER_KEY_SECRET_NAME=AzureFormRecognizerKey
AZURE_SEARCH_KEY_SECRET_NAME=AzureSearchKey
AZURE_FOUNDRY_KEY_SECRET_NAME=AzureFoundryKey

# External Fraud Scoring API
# For local development, point this to the MCP server HTTP endpoint that exposes the fraud tool:

# For Fast API server running locally, use the following URL:
FRAUD_API_URL=http://127.0.0.1:8000/fraud-score

# For MCP server running locally, use the following URL:
# FRAUD_API_URL=http://127.0.0.1:8000/mcp
FRAUD_API_KEY=

# Local MCP server
MCP_HOST=127.0.0.1
MCP_PORT=8000

# Logging
LOG_LEVEL=INFO
ENVIRONMENT=development
